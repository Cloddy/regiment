{
  "name": "regiment-25-front",
  "version": "1.0.0",
  "main": "./main.tsx",
  "author": "KTS",
  "license": "MIT",
  "scripts": {
    "rm-public": "rm -rf ./public",
    "rm-source-maps": "find ./public -name *.js.map -type f -delete",
    "dev": "cross-env API_URL=/api/ NODE_ENV=development TS_NODE_PROJECT='./tsconfig.webpack.json' webpack serve --mode development",
    "dev:local-api": "cross-env API_PROXY_PORT=3000 yarn dev",
    "build": "yarn rm-public & cross-env NODE_ENV=production TS_NODE_PROJECT='./tsconfig.webpack.json' webpack --mode production && yarn run rm-source-maps",
    "build-odr": "yarn rm-public & cross-env IS_ODR=true NODE_ENV=production TS_NODE_PROJECT='./tsconfig.webpack.json' webpack --mode production && yarn run rm-source-maps",
    "tsc:check": "tsc --project tsconfig.json",
    "lint": "eslint --ignore-path .gitignore . --ext ts,.tsx,.js,.jsx",
    "lint:fix": "eslint --ignore-path .gitignore . --ext ts,.tsx,.js,.jsx --fix ",
    "stylelint": "stylelint --ignore-path .gitignore \"**/*.{css,scss}\"",
    "stylelint:fix": "stylelint --ignore-path .gitignore \"**/*.{css,scss}\" --fix",
    "format": "yarn lint:fix && yarn stylelint:fix",
    "deploy-vk": "CI_URLS=true vk-miniapps-deploy",
    "vk-tunnel": "vk-tunnel --insecure=0 --http-protocol=https --ws-protocol=wss --host=0.0.0.0 --port=9091",
    "precommit": "yarn tsc:check && lint-staged",
    "prepare": "husky",
    "minify-images": "node --loader ts-node/esm tools/images/imagemin.mts"
  },
  "homepage": "./",
  "commands": [
    "yarn build"
  ],
  "lint-staged": {
    "*.{ts,tsx,js,jsx,scss,css}": [
      "yarn prettier --write"
    ],
    "*.{ts,js}?(x)": [
      "yarn lint"
    ],
    "*.{scss,css}": [
      "yarn stylelint"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "not IE 11"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version",
      "last 1 ie version"
    ]
  },
  "dependencies": {
    "@kts-front/call-api": "file:./libs/kts-front/call-api-1.0.3.tgz",
    "@kts-front/types": "file:./libs/kts-front/types-0.0.5.tgz",
    "@ktsstudio/mediaproject-stores": "^4.1.0",
    "@ktsstudio/mediaproject-style": "^4.0.0",
    "@ktsstudio/mediaproject-utils": "^6.0.0",
    "@ktsstudio/mediaproject-vk": "^3.0.1",
    "@sentry/react": "^8.9.2",
    "@types/react-input-mask": "^3.0.6",
    "@vkontakte/icons": "^2.104.1",
    "@vkontakte/vk-bridge": "^2.15.6",
    "@vkontakte/vk-bridge-react": "^1.0.1",
    "@vkontakte/vkjs": "^1.3.0",
    "@vkontakte/vkui": "^6.7.4",
    "axios": "^1.7.9",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.0",
    "core-js": "^3.36.1",
    "eruda": "^3.0.1",
    "history": "^5.3.0",
    "konva": "^9.3.20",
    "mobx": "^6.12.1",
    "mobx-react": "^9.1.0",
    "react": "^18.2.0",
